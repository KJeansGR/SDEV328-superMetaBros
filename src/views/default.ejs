<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/css/styles.css" />
    <script src="/js/homePage.js" defer></script>
</head>
<body>
<%- include('partials/header') %>

<header class="hero">
    <div class="hero-content">
        <h1><%= title %></h1>
        <p><%= subtitle %></p>
        <p><%= howToOrder %></p>
    </div>
    <div class="hero-image">
        <img src="/images/healthy-drinks.webp" alt="Drinks image" />
    </div>
</header>

<main class="container">
    <div class="auth-actions"> 
        <a href="/smb/products" class="btn-primary">View Products</a> 
        
        <a href="/smb/loginPage" class="btn-secondary">Log In</a> 
        <a href="/smb/loginPage" class="btn-secondary">Sign Up</a> 
    </div>

   <h2>Our Featured Beverages</h2>

    <div class="search-container" ><!-- search form-->
        <form id="searchForm">
            <label for="search">Search for beverage</label>
            <input type="text" name="search" id="search" placeholder="search...">
            <label for="sortPrice">Price</label>
            <select id="sortPrice" name="sortPrice">
                <option value="none" >none</option>
                <option value="asc">low to high</option>
                <option value="desc">high to low</option>
            </select>
            <label for="sortCategory">category</label>
            <select id="sortCategory" name="sortCategory">
                <option value="none">none</option>
                <option value="Coffee">Coffee</option>
                <option value="Soda">Soda</option>
                <option value="Energy Drink">Energy Drink</option>
                <option value="Smoothie">Smoothie</option>
                <option value="Slush">Slush</option>
            </select>
            <button type="submit" id="serchFormBtn">apply</button>
        </form>
    </div> 

   <section class="products-grid">
       <% if (typeof products !== 'undefined' && products.length > 0) { %>
           <% products.forEach(product => { %>
               <div class="card product-card">
                   <h3><%= product.itemName %></h3>
                   <span class="category-badge"><%= product.category %></span>
                   <p class="product-info"><%= product.info %></p>
                   <div class="card-footer">
                        <span class="product-price">$<%= Number(product.price).toFixed(2) %></span>
                       <a href="/smb/products/<%= product.id %>" class="btn-sm">View Details</a>
                   </div>
               </div>
           <% }) %>
       <% } else { %>
           <p>No delicious drinks available at the moment. Check back soon!</p>
       <% } %>
   </section>
</main>

<%- include('partials/footer') %>

</body>
</html>
