<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/css/styles.css" />
    <script src="/js/homePage.js" defer></script>
</head>
<body>

    <header class="hero">
        <div class="hero-content">
            <h1><%= title %></h1>
            <p><%= subtitle %></p>
        </div>

        <div class="hero-image">
            <img
                src="/images/healthy-drinks.webp"
                alt="Drinks image"
            />
        </div>
    </header>
<main class="container">
   <div> 
     <button id="signUpBtn">Sign up</button> 
     <button id="logInBtn">log in</button> 
     <button id="allProductsBtn"> view products</button> 
   </div>
    <section class="card">
        <h2>Website currently under construction...</h2>

        <p>
            <strong>When we are live expect:</strong>
        </p>

        <ul>
            <li>A growing catalog of specialty and themed beverages.</li>
            <li>Dynamic product pages powered by our Node + Express MVC backend.</li>
            <li>Real-time beverage data loaded directly from MySQL.</li>
        </ul>

    </section>
</main>

    <footer class="footer">
        <p>superMetaBros Node + Express MVC Ecommerce Service</p>
    </footer>

</body>
</html>
